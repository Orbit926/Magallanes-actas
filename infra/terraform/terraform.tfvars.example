# ──────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in
# ──────────────────────────────────────────────

aws_profile = "default"
aws_region  = "us-east-1"

default_tags = {
  Project   = "magallanes"
  ManagedBy = "terraform"
}

project_name = "magallanes"
environment  = "dev"

# ── Email ────────────────────────────────────────
seller_email    = "vendedor@ejemplo.com"
zoho_from_email = "noreply@tudominio.com"

# ── Zoho API ────────────────────────────────────
zoho_api_base_url      = "https://mail.zoho.com"
secret_name_zoho_token = "magallanes/zoho-oauth-token"

# ── CORS (use your frontend domain in prod) ─────
cors_allowed_origins = ["*"]

# ── Lambda tuning ────────────────────────────────
lambda_memory  = 256
lambda_timeout = 30
