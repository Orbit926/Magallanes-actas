# ──────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in
# ──────────────────────────────────────────────

aws_profile = "default"
aws_region  = "us-east-1"

default_tags = {
  Project   = "magallanes"
  ManagedBy = "terraform"
}

project_name = "magallanes"
environment  = "dev"

# ── Email ────────────────────────────────────────
seller_email    = "vendedor@ejemplo.com"
zoho_from_email = "noreply@tudominio.com"

# ── Zoho SMTP credentials ───────────────────────
zoho_smtp_host = "smtp.zoho.com"
zoho_smtp_port = 465
zoho_smtp_user = "tu-cuenta@tudominio.com"
zoho_smtp_pass = "tu-app-password-aqui"

# ── CORS (use your frontend domain in prod) ─────
cors_allowed_origins = ["*"]

# ── Lambda tuning ────────────────────────────────
lambda_memory  = 256
lambda_timeout = 30
